# -----------------------------------------------------------------------------
# 5. CLASSIFY SEQUENCE GROUPS
# -----------------------------------------------------------------------------
# Rules (applied to people who have children — childless are a separate group):
#
#   ON SEQUENCE:          ed before (or same age as) work,
#                         work before (or same age as) partner,
#                         partner before (or same age as) child
#                         — and has a qualification
#
#   CHILD BEFORE PARTNER: has a child; child arrived before partnership
#
#   PARTNER BEFORE WORK:  has a child; partnered but child arrived before
#                         ever working full-time
#
#   NO QUALIFICATION:     left education without a qualification (regardless
#                         of subsequent sequence)
#
#   PARTIAL/OTHER:        education done and working, but no child yet /
#                         other orderings
#
#   NO CHILD:             no child observed in the panel (separate group)

sequence_df <- milestone_df %>%
  mutate(
    has_child_ever   = !is.na(age_first_child),
    has_partner_ever = !is.na(age_first_partner),
    has_work_ever    = !is.na(age_first_work),
    has_ed_ever      = !is.na(age_first_ed),
    
    sequence_group = {
      # Build a named vector of ages for each observed milestone
      # then sort by age and paste the labels together
      pmap_chr(
        list(age_first_ed, age_first_work, age_first_partner, age_first_child),
        function(ed, work, partner, child) {
          events <- c(
            "Education"  = ed,
            "Employment" = work,
            "Marriage"   = partner,
            "Child"      = child
          )
          # Drop milestones never observed
          events <- events[!is.na(events)]
          
          if (length(events) == 0) return("No milestones observed")
          
          # Sort by age; where ages are tied, order is arbitrary within tie
          events_sorted <- sort(events)
          
          paste(names(events_sorted), collapse = "; ")
        }
      )
    }
  )


# Summary table on sequence

sequence_su <- sequence_df %>% 
  group_by(sequence_group) %>% 
  summarise(n = n()) %>% 
  ungroup() %>% 
  mutate(prop = n/sum(n))

# -----------------------------------------------------------------------------
# 6. ATTACH OUTCOME — INCOME AT OUTCOME AGE
# -----------------------------------------------------------------------------
# For each person, take income observed when they are between
# OUTCOME_AGE_MIN and OUTCOME_AGE_MAX. Average across available waves
# in that age window to reduce noise.

outcomes <- cohort %>%
  filter(
    age_dv >= OUTCOME_AGE_MIN,
    age_dv <= OUTCOME_AGE_MAX,
    !is.na(equiv_income),
    equiv_income > 0
  ) %>%
  group_by(pidp) %>%
  summarise(
    mean_equiv_income = mean(equiv_income, na.rm = TRUE),
    mean_log_income   = mean(log_income,   na.rm = TRUE),
    n_outcome_waves   = n(),
    # Use the most recent longitudinal weight in the outcome window
    weight_long       = last(indpxus_xw[order(wave_n)]),
    weight_cs         = last(indinus_xw[order(wave_n)]),
    .groups = "drop"
  )

# Poverty: below 60% of median equivalised income in each wave
# Compute wave-specific median, flag individuals below threshold
poverty_flags <- cohort %>%
  filter(age_dv >= OUTCOME_AGE_MIN, age_dv <= OUTCOME_AGE_MAX,
         !is.na(equiv_income), equiv_income > 0) %>%
  group_by(wave_n) %>%
  mutate(wave_median = median(equiv_income, na.rm = TRUE),
         poor        = as.integer(equiv_income < 0.6 * wave_median)) %>%
  ungroup() %>%
  group_by(pidp) %>%
  summarise(pct_waves_poor = mean(poor, na.rm = TRUE), .groups = "drop")

outcomes <- outcomes %>%
  left_join(poverty_flags, by = "pidp")

# Combine everything
analytic <- milestone_df %>%
  inner_join(outcomes, by = "pidp") %>%
  filter(!is.na(sequence_group)) %>%
  # Relevel: on_sequence is reference category
  mutate(
    sequence_group = factor(sequence_group,
                            levels = c("on_sequence",
                                       "child_before_partner",
                                       "child_before_work",
                                       "partial_sequence",
                                       "no_qualification",
                                       "no_child")),
    female     = as.integer(sex_dv == 2),
    eth_white  = as.integer(racel_dv == 1),   # white British
    par_degree = as.integer(par_ed_degree == 1)
  )

message("\nAnalytic sample N = ", nrow(analytic))
cat("\n--- Sequence group in analytic sample ---\n")
