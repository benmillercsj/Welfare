# -----------------------------------------------------------------------------
# 1. LOAD AND STACK ALL WAVES
# -----------------------------------------------------------------------------
# We extract a minimal set of variables from each wave's indresp and hhresp,
# then row-bind into one long panel dataset.

load_wave <- function(wave_letter) {
  
  prefix <- wave_letter
  ind_path  <- file.path(import_path, paste0(prefix, "_indresp.tab"))
  hh_path   <- file.path(import_path, paste0(prefix, "_hhresp.tab"))
  
  message("Loading wave ", toupper(wave_letter), "...")
  
  # --- Individual file ---
  ind_vars <- c(
    "pidp",            # permanent person ID (time-stable)
    paste0(prefix, "_hidp"),          # household ID this wave
    paste0(prefix, "_intdaty_dv"),    # interview year
    paste0(prefix, "_intdatm_dv"),    # interview month
    paste0(prefix, "_birthy"),        # birth year
    paste0(prefix, "_sex_dv"),        # sex
    paste0(prefix, "_age_dv"),        # age at interview
    paste0(prefix, "_racel_dv"),      # ethnicity
    paste0(prefix, "_gor_dv"),        # government office region
    paste0(prefix, "_jbstat"),        # labour force status
    paste0(prefix, "_jbbgy"),        # year started current job
    paste0(prefix, "_mastat_dv"),     # marital/cohabitation status
    paste0(prefix, "_lmar1y_dv"),     # year of marriage
    paste0(prefix, "_nchild_dv"),     # number of own children in HH
    paste0(prefix, "_hiqual_dv"),     # highest qualification
    paste0(prefix, "_feend"),         # age left full-time education
    paste0(prefix, "_indinus_xw"),    # cross-sectional weight
    paste0(prefix, "_indpxus_xw"),    # longitudinal weight
    # Parental education (wave 1 only, but include for merging)
    paste0(prefix, "_paedqf"),        # father's education
    paste0(prefix, "_maedqf")         # mother's education
  )
  
  ind_raw <- read_delim(ind_path) %>%
    select(any_of(ind_vars))
  
  
  # Standardise column names (strip wave prefix)
  names(ind_raw) <- gsub(paste0("^", prefix, "_"), "", names(ind_raw))
  ind_raw$wave   <- wave_letter
  ind_raw$wave_n <- which(WAVE_LETTERS == wave_letter)
  
  # --- Household file (for poverty line) ---
  hh_vars <- c(
    paste0(prefix, "_hidp"),
    paste0(prefix, "_fihhmnlabnet_dv"),    # net hh labour income
    paste0(prefix, "_ieqmoecd_dv"),   # OECD scale
    paste0(prefix, "_hhsize")
  )
  
  hh_raw <- read_delim(hh_path) %>%
    select(any_of(hh_vars))
  names(hh_raw) <- gsub(paste0("^", prefix, "_"), "", names(hh_raw))
  
  # Merge
  combined <- ind_raw %>%
    left_join(hh_raw, by = "hidp")
  
  return(combined)
}

# Load all waves and stack
panel_raw <- map_dfr(WAVE_LETTERS, load_wave)



# -----------------------------------------------------------------------------
# 2. CLEAN AND RECODE
# -----------------------------------------------------------------------------

panel <- panel_raw %>%
  mutate(
    # Recode negatives (UKHLS uses -1 = missing, -2 = inapplicable, etc.)
    across(where(is.numeric), ~ ifelse(. < 0, NA_real_, .)),
    
    # --- Employment: full-time work ---
    # jbstat: 1 = self-employed, 2 = employed; jbft_dv would be cleaner if
    # available, but jbstat 1 or 2 captures any employment; filter on hours
    # via jbhrs if you want strict full-time (>= 30 hrs). Here we use
    # jbstat %in% 1:2 as a broad "in work" flag; adjust if needed.
    employed_ft = case_when(
      jbstat %in% c(1, 2, 5, 11, 14, 15) ~ 1L,
      jbstat %!in% c(3, 4, 6, 7, 8, 9, 10, 12, 13, 97) ~ 0L,
      TRUE                ~ NA_integer_
    ),
    
    # --- Partnership ---
    # mastat_dv: 1=married, 2=civil partner, 3=separated, 4=divorced,
    #            5=widowed, 6=never married, 10=cohabiting
    married = case_when(
      mastat_dv %in% c(1, 2)                                    ~ 1L,
      INCLUDE_COHABITATION & mastat_dv == 10                    ~ 1L,
      mastat_dv %in% c(3:6, if (!INCLUDE_COHABITATION) 10)      ~ 0L,
      TRUE                                                       ~ NA_integer_
    ),
    
    # --- Children ---
    has_child = case_when(
      nchild_dv >= 1 ~ 1L,
      nchild_dv == 0 ~ 0L,
      TRUE           ~ NA_integer_
    ),
    
    # --- Education complete ---
    # Person is "education complete" if they have left FT education
    # (feend is non-missing and > 0) AND have a qualification
    # ed_complete = case_when(
    #   !is.na(feend_filled) & feend_filled > 0 & hiqual_dv <= ED_COMPLETE_QUAL_MAX ~ 1L,
    #   !is.na(feend_filled) & feend_filled > 0 & hiqual_dv == 9                    ~ 0L,
    #   TRUE                                                            ~ NA_integer_
    # ),
    # 
    # Parental education: collapse to degree vs not
    par_ed_degree = case_when(
      paedqf %in% c(1, 2) | maedqf %in% c(1, 2) ~ 1L,   # at least one parent degree
      !is.na(paedqf) | !is.na(maedqf)            ~ 0L,
      TRUE                                        ~ NA_integer_
    ),
    
    # Equivalised income (real terms — deflate to a base year if needed)
    # ieqmoecd_dv is already equivalised monthly net income in nominal £
    hh_adjusted_income = fihhmnlabnet_dv/ieqmoecd_dv,
    log_income   = log(pmax(hh_adjusted_income, 1)),  # floor at £1 to avoid -Inf
    
    # Interview year for time-ordering
    year = intdaty_dv
  )


