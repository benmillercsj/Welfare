# =============================================================================
# SUCCESS SEQUENCE REPLICATION — Understanding Society (UKHLS) Waves 1–15
# =============================================================================
# Replicates the Sawhill/Venator "Success Sequence" approach:
#   1. Finish education
#   2. Work full-time
#   3. Marry (or cohabit — toggle below)
#   4. Have first child
# Outcome: equivalised net household income; poverty rate
#
# Panel approach: follow a birth cohort prospectively across waves,
# observing the timing of each milestone in real time.
#
# Data source: UK Data Service, Understanding Society (SN 6614)
# Required files per wave: indresp, hhresp (and child file for fertility)

# Birth cohort: people born in these years will be your analytic sample.
# They should be young enough to have all milestones potentially observable,
# and old enough that most have passed through the sequence by the end of data.
# Waves cover roughly 2009–2024 (wave 1 fieldwork 2009–2011).
# Born 1980–1993 means they are ~16–29 at wave 1 and ~31–44 at wave 15.
BIRTH_COHORT_MIN <- 1980
BIRTH_COHORT_MAX <- 1993

# Minimum age at which we start looking for sequence events
SEQUENCE_START_AGE <- 16

# Age at which we "score" the sequence (must have left education by then)
OUTCOME_AGE_MIN <- 28
OUTCOME_AGE_MAX <- 34

# Include cohabitation as equivalent to marriage? (TRUE = yes)
INCLUDE_COHABITATION <- FALSE

# Wave letters a–o for waves 1–15
WAVE_LETTERS <- letters[2:15]

# Education: what counts as "completed"?
# hiqual_dv codes: 1=Degree, 2=Other higher, 3=A-level, 4=GCSE, 5=Other,
#                  9=No qual; feend = age left full-time education
# We define "completed" as having left full-time education (feend is observed)
# AND having at least some qualification (hiqual_dv < 9)
# You can tighten this to degree-level (hiqual_dv <= 2) if preferred.
ED_COMPLETE_QUAL_MAX <- 8   # hiqual_dv <= this value => has a qualification

