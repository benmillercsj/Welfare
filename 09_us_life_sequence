# -----------------------------------------------------------------------------
# 8. REGRESSION ANALYSIS
# -----------------------------------------------------------------------------
# Model 1: Raw (no controls)
# Model 2: Controls for sex, ethnicity, parental education, region
# Model 3: Model 2 + interaction with sex

# Set up survey design object using longitudinal weights
svy_design <- analytic %>%
  as_survey_design(weights = weight_long)

# ---- Model 1: Income ~ sequence (unadjusted) --------------------------------
m1_income <- svyglm(
  mean_log_income ~ sequence_group,
  design = svy_design,
  family = gaussian()
)

# ---- Model 2: Income ~ sequence + controls ----------------------------------
m2_income <- svyglm(
  mean_log_income ~ sequence_group + female + eth_white + par_degree +
    factor(gor_dv),
  design = svy_design,
  family = gaussian()
)

# ---- Model 3: Poverty (logistic) --------------------------------------------
# Convert pct_waves_poor to binary (poor in majority of outcome waves)
analytic <- analytic %>%
  mutate(ever_poor = as.integer(pct_waves_poor > 0.5))

svy_design2 <- analytic %>%
  as_survey_design(weights = weight_long)

m3_poverty <- svyglm(
  ever_poor ~ sequence_group + female + eth_white + par_degree +
    factor(gor_dv),
  design = svy_design2,
  family = quasibinomial()
)

# ---- Model 4: By sex --------------------------------------------------------
# Run Model 2 separately for men and women
m4_men <- svyglm(
  mean_log_income ~ sequence_group + eth_white + par_degree + factor(gor_dv),
  design = svy_design %>% filter(female == 0),
  family = gaussian()
)

m4_women <- svyglm(
  mean_log_income ~ sequence_group + eth_white + par_degree + factor(gor_dv),
  design = svy_design %>% filter(female == 1),
  family = gaussian()
)

# --- Print coefficient tables ------------------------------------------------
cat("\n=== Model 1: Log income ~ sequence (unadjusted) ===\n")
print(summary(m1_income)$coefficients[1:6, ])

cat("\n=== Model 2: Log income ~ sequence + controls ===\n")
print(summary(m2_income)$coefficients[1:6, ])

cat("\n=== Model 3: Poverty ~ sequence + controls (logistic) ===\n")
print(summary(m3_poverty)$coefficients[1:6, ])

cat("\n=== Model 4: Log income ~ sequence (men only) ===\n")
print(summary(m4_men)$coefficients[1:6, ])

cat("\n=== Model 4: Log income ~ sequence (women only) ===\n")
print(summary(m4_women)$coefficients[1:6, ])


# -----------------------------------------------------------------------------
# 9. PREDICTED INCOME BY SEQUENCE GROUP (MARGINAL MEANS)
# -----------------------------------------------------------------------------
# Back out predicted income at average covariate values

pred_grid <- expand.grid(
  sequence_group = levels(analytic$sequence_group),
  female         = mean(analytic$female, na.rm = TRUE),
  eth_white      = mean(analytic$eth_white, na.rm = TRUE),
  par_degree     = mean(analytic$par_degree, na.rm = TRUE),
  gor_dv         = as.integer(names(sort(table(analytic$gor_dv),
                                         decreasing = TRUE))[1])  # modal region
)

pred_grid$pred_log_income <- predict(m2_income, newdata = pred_grid,
                                     type = "response")
pred_grid$pred_income_gbp <- exp(pred_grid$pred_log_income)

cat("\n--- Predicted monthly equivalised income by sequence group ---\n")
pred_grid %>%
  select(sequence_group, pred_income_gbp) %>%
  arrange(desc(pred_income_gbp)) %>%
  print()


